@using DMBBootstrapBuilder
@using DMBComponentBuilder
@using DMBEffectBuilder
@using DMBPageBuilder
@{
    Layout = "_Layout";
}

@* ── Hero ── *@
@using (Html.SectionBuilder().SetHeight(125, UnitSize.px).BootstrapBackgroundEffect(VariantStyle.Normal).Begin())
{
    @using (Html.FlexBlockBuilder().SetAlignItemsCenter().SetJustifyContentCenter().Begin())
    {
        @using (Html.BlockBuilder().AsTextCenter().Begin())
        {
            @Html.TitleBuilder().SetTitle("Getting Started — ComponentBuilder", TitleLevel.One).Render()
            @using (Html.PB_P().AsLead().Begin())
            {
                @:Use higher-level workflow components in BootstrapBuilder pages.
            }
        }
    }
}

@using (Html.ContainerBuilder().SetPadding(SpacingSide.Y, SpacingSize.Five).Begin())
{
    @using (Html.RowBuilder().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).Begin())
        {
            @* ── Step 1 ── *@
            @Html.TitleBuilder().SetTitle("1. Install the NuGet Package", TitleLevel.Two).AsSectionHeading().Render()
            @using (Html.PB_P().Begin())
            {
                @:Install
                @using (Html.PB_Span().AsMonospace().Begin())
                {
                    @:DMBComponentBuilder
                }
                @: alongside
                @using (Html.PB_Span().AsMonospace().Begin())
                {
                    @:DMBPageBuilder
                }
                @: and
                @using (Html.PB_Span().AsMonospace().Begin())
                {
                    @:DMBBootstrapBuilder
                }
                @:. ComponentBuilder provides product-level UI patterns such as timelines, roadmaps, steps and media viewers.
            }
            @(Html.CodeBlock("dotnet add package DMBComponentBuilder", CodeLanguage.Bash)
                .SetTitle("Install DMBComponentBuilder")
                .SetCopyButton())

            @* ── Step 2 ── *@
            @Html.TitleBuilder().SetTitle("2. Configure Services", TitleLevel.Two).AsSubSectionHeading().Render()
            @using (Html.PB_P().Begin())
            {
                @:Load ComponentBuilder after its rendering dependencies. Order matters — PageBuilder must be registered before BootstrapBuilder and ComponentBuilder.
            }
            @(Html.CodeBlock(@"using DMBPageBuilder;
using DMBBootstrapBuilder;
using DMBComponentBuilder;

PageBuilderConfiguration.LoadCommonConfig(builder);
BootstrapBuilderConfiguration.LoadCommonConfig(builder);
ComponentBuilderConfiguration.LoadCommonConfig(builder);", CodeLanguage.CSharp)
                .SetTitle("Program.cs")
                .SetCopyButton())

            @* ── Step 3 ── *@
            @Html.TitleBuilder().SetTitle("3. Add Razor Imports", TitleLevel.Two).AsSubSectionHeading().Render()
            @using (Html.PB_P().Begin())
            {
                @:In your
                @using (Html.PB_Span().AsMonospace().Begin())
                {
                    @:_ViewImports.cshtml
                }
                @:, add the ComponentBuilder namespace to make all component builders available in your views.
            }
            @(Html.CodeBlock(@"@using DMBPageBuilder
@using DMBBootstrapBuilder
@using DMBComponentBuilder", CodeLanguage.CSharp)
                .SetTitle("_ViewImports.cshtml")
                .SetCopyButton())

            @* ── Step 4 ── *@
            @Html.TitleBuilder().SetTitle("4. Pick a Component Family", TitleLevel.Two).AsSubSectionHeading().Render()
            @using (Html.PB_P().Begin())
            {
                @:Start from a demo page before integrating a component into production views. Use Timeline or Roadmap for chronological views, Step by Step or Checkout for guided workflows.
            }
            @(Html.CodeBlock(@"@Html.TimelineBuilder()
    .AddItem(new TimelineItem { Title = ""Phase 1"", Status = TimelineStatus.Done })
    .AddItem(new TimelineItem { Title = ""Phase 2"", Status = TimelineStatus.Active })
    .Render()", CodeLanguage.CSharp)
                .SetTitle("Timeline example")
                .SetCopyButton())

            @* ── Available Components quick reference ── *@
            @using (Html.BlockBuilder().AsInfoCallout().Begin())
            {
                @using (Html.FlexBlockBuilder().Begin())
                {
                    @using (Html.BlockBuilder().AsCalloutIcon().Begin())
                    {
                        @using (Html.PB_Span().AddClass("bi bi-collection-fill fs-2 text-info").Begin()) { }
                    }
                    @using (Html.BlockBuilder().Begin())
                    {
                        @Html.TitleBuilder().SetTitle("Available Components", TitleLevel.Five).AsAlertHeading().Render()
                        @using (Html.BlockBuilder().AsSidebarRow().Begin())
                        {
                            @using (Html.PB_Span().AsMonospaceSmall().Begin())
                            {
                                @:Html.TimelineBuilder()
                            }
                        }
                        @using (Html.BlockBuilder().AsSidebarRow().Begin())
                        {
                            @using (Html.PB_Span().AsMonospaceSmall().Begin())
                            {
                                @:Html.RoadmapBuilder()
                            }
                        }
                        @using (Html.BlockBuilder().AsSidebarRow().Begin())
                        {
                            @using (Html.PB_Span().AsMonospaceSmall().Begin())
                            {
                                @:Html.CheckoutProgressBuilder()
                            }
                        }
                        @using (Html.BlockBuilder().AsSidebarRow().Begin())
                        {
                            @using (Html.PB_Span().AsMonospaceSmall().Begin())
                            {
                                @:Html.StepByStepBuilder()
                            }
                        }
                        @using (Html.BlockBuilder().AsSidebarRow().Begin())
                        {
                            @using (Html.PB_Span().AsMonospaceSmall().Begin())
                            {
                                @:Html.CodeBlock(...)
                            }
                        }
                    }
                }
            }

            @* ── Next Step ── *@
            @using (Html.BlockBuilder().AsSidebarNote().Begin())
            {
                @using (Html.BlockBuilder().AsTextCenter().Begin())
                {
                    @Html.TitleBuilder().SetTitle("Understand how ComponentBuilder layers on top of BootstrapBuilder and PageBuilder?", TitleLevel.Four).Render()
                    @using (Html.PB_P().AsSmallMuted().Begin())
                    {
                        @:Check out the architecture guide to understand how ComponentBuilder is structured and how product data flows to rendered markup.
                    }
                    @Html.Button(ActionItemFactory.AspRoute("ComponentBuilder", "Architecture").SetTitle("Architecture").SetIcon(IconStruct.Bootstrap("bi-diagram-3")).SetVariant(VariantStyle.Primary)).Render()
                }
            }
        }
    }
}
