@model DMBComponentBuilder.GDFFestival
@using DMBBootstrapBuilder
@using DMBPageBuilder
@using (Html.BlockBuilder().AddClass("border rounded-3 p-4").Begin())
{
    @using (Html.BlockBuilder().AddClass("d-flex align-items-start gap-3").Begin())
    {
        @using (Html.PB_Span().AddClass("bi bi-journal-code fs-3 text-primary").Begin()) { }
        @using (Html.BlockBuilder().Begin())
        {
            @Html.TitleBuilder().SetTitle(Model.Name, TitleLevel.Three).Render()
            @using (Html.BlockBuilder().AddClass("text-body-secondary").Begin())
            {
                @:@Model.StartDate.ToString("d") - @Model.EndDate.ToString("d")
            }
            @using (Html.BlockBuilder().AddClass("mt-3").Begin())
            {
                @:A multi-day festival can keep its own markup while sharing the same component entry point.
            }
        }
    }
}
