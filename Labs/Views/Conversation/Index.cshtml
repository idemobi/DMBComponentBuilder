@Html.TitleBuilder().SetTitle("ConversationBuilder", TitleLevel.One).AsSectionHeading().Render()

@using (Html.PB_P().AsMuted().Begin())
{
    @:Reusable participant conversations for support tickets, forums, moderation threads, and multi-person discussions.
}

@Html.SeparatorBuilder().UsePageSpacing()

@Html.TitleBuilder().SetTitle("Support ticket conversation", TitleLevel.Two).AsSectionHeading().Render()

@(Html.ConversationBuilder()
    .SetCurrentParticipantKey("admin-14")
    .SetEmptyMessage("No message in this support ticket.")
    .SetMessages(supportMessages)
    .Render())

@Html.SeparatorBuilder().UsePageSpacing()

@Html.TitleBuilder().SetTitle("Forum conversation", TitleLevel.Two).AsSectionHeading().Render()

@(Html.ConversationBuilder()
    .SetCurrentParticipantKey("current-user")
    .SetCurrentParticipantVariant(VariantStyle.Success)
    .SetMessages(forumMessages)
    .Render())

@Html.SeparatorBuilder().UsePageSpacing()

@Html.TitleBuilder().SetTitle("Empty state", TitleLevel.Two).AsSectionHeading().Render()

@(Html.ConversationBuilder()
    .SetCurrentParticipantKey("current-user")
    .SetEmptyMessage("Start the conversation by writing the first message.")
    .Render())

@Html.SeparatorBuilder().UsePageSpacing()

@Html.TitleBuilder().SetTitle("Error state", TitleLevel.Two).AsSectionHeading().Render()

@(Html.ConversationBuilder()
    .SetErrorMessage("The conversation cannot be loaded at the moment.")
    .Render())
